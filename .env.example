# ============================================================================
# Sentinel-OSINT environment variables — copy to .env and fill in.
# ALL secrets are server-only (Cloudflare Worker SSR). Never expose to browser.
# ============================================================================

# --- Required ---
# Tavily advanced search (briefs + news radius sweep)
TAVILY_API_KEY=tvly-xxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional (mock fallback if absent) ---
# Censys Platform API v3 (ICS/SCADA discovery)
CENSYS_API_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Optional (skipped if absent) ---
# NASA FIRMS active-fire CSV feed
FIRMS_MAP_KEY=xxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx

# --- Auto-provided by Lovable connector at runtime ---
# LOVABLE_API_KEY=
# MAPBOX_API_KEY=
# VITE_LOVABLE_CONNECTOR_MAPBOX_PUBLIC_TOKEN=
